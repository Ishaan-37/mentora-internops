# =============================================================
#  InternOps Backend — Environment Variables
#  Copy this file to .env and fill in real values
#  NEVER commit .env to git
# =============================================================

# --- Server ---
NODE_ENV=development
PORT=5000

# --- PostgreSQL ---
# Local:   postgres://user:password@localhost:5432/internops
# Supabase: get from Project Settings → Database → Connection string
DATABASE_URL=postgres://postgres:password@localhost:5432/internops

# --- JWT ---
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_char_random_hex_string
JWT_EXPIRES_IN=1h

# Refresh token (longer lived, stored in httpOnly cookie)
JWT_REFRESH_SECRET=replace_with_another_64_char_random_hex_string
JWT_REFRESH_EXPIRES_IN=7d

# --- Bcrypt ---
BCRYPT_ROUNDS=10

# --- File Upload ---
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=./uploads

# --- AWS S3 (optional, for production file storage) ---
# Leave blank to use local disk storage in development
AWS_S3_BUCKET=
AWS_S3_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- CORS ---
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# --- Timezone ---
TZ=Asia/Kolkata
